# Telegram API credentials (get from https://my.telegram.org)
API_ID=12345678
API_HASH=your_api_hash_here

# Bot token (get from @BotFather on Telegram)
BOT_TOKEN=your_bot_token_here

# Optional: comma-separated list of Telegram user IDs allowed to use the bot.
# Leave empty to allow ALL users (not recommended for public bots).
ALLOWED_USERS=

# Optional: path to a custom gallery-dl config file.
GALLERY_DL_CONFIG_PATH=

# Optional: gallery-dl config as a base64-encoded JSON string (preferred over
# GALLERY_DL_CONFIG_JSON).  Encode with: base64 < gallery-dl.conf
# Used only when GALLERY_DL_CONFIG_PATH is not set.
GALLERY_DL_CONFIG_B64=

# Optional: gallery-dl config as a raw JSON string (legacy; use
# GALLERY_DL_CONFIG_B64 instead to avoid quoting/escaping issues).
# Used only when neither GALLERY_DL_CONFIG_PATH nor GALLERY_DL_CONFIG_B64 is set.
GALLERY_DL_CONFIG_JSON=

# ---------------------------------------------------------------------------
# Media processing (gallery-dl integration)
# ---------------------------------------------------------------------------

# Set to true to pass --yt-dlp to gallery-dl so that HLS/DASH streams and
# other yt-dlp-handled URLs are downloaded automatically.
# Requires yt-dlp to be installed (already included in requirements.txt).
YTDL_ENABLED=false

# Set to true to pass --ugoira-conv to gallery-dl so that Pixiv Ugoira ZIP
# files are converted to WebM/MP4 video using FFmpeg.
# Requires ffmpeg to be installed (included in the Docker image).
UGOIRA_CONVERT=false

# Set to true to pass --ugoira-conv-mkvmerge to gallery-dl so that Ugoira
# files are converted to MKV with accurate per-frame timecodes via mkvmerge.
# Requires mkvtoolnix (mkvmerge) to be installed (included in the Docker image).
UGOIRA_MKVMERGE=false

# ---------------------------------------------------------------------------
# Proxy (optional, requires PySocks)
# ---------------------------------------------------------------------------

# Proxy scheme: "socks5", "socks4", or "http".
PROXY_SCHEME=

# Proxy hostname (e.g. "127.0.0.1" or "proxy.example.com").
PROXY_HOSTNAME=

# Proxy port (e.g. 1080).
PROXY_PORT=

# Optional proxy credentials.
PROXY_USERNAME=
PROXY_PASSWORD=

# ---------------------------------------------------------------------------
# Web UI (for PaaS platforms that require an active HTTP port, e.g. Render,
# Railway, Fly.io, Heroku).
# ---------------------------------------------------------------------------

# Set to true to enable the lightweight HTTP status page.
WEBUI=false

# Host and port for the web UI. 0.0.0.0 listens on all interfaces.
WEBUI_HOST=0.0.0.0
WEBUI_PORT=8080
